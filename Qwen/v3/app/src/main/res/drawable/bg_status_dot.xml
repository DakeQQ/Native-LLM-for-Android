<?xml version="1.0" encoding="utf-8"?>
<!-- "Online / active" status dot. A mint core with a faint ring; the row pulses its alpha/scale
     so it reads as a live indicator. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <solid android:color="@color/statusOnline" />
    <stroke
        android:width="2dp"
        android:color="@color/statusGlow" />
</shape>
