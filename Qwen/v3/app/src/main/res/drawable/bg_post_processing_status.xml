<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/ui_corner_radius" />
            <solid android:color="@color/postProcessOrange" />
            <stroke
                android:width="1dp"
                android:color="@color/postProcessOrangeStroke" />
        </shape>
    </item>
    <item android:top="1dp" android:left="1dp" android:right="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/ui_corner_radius_inner" />
            <gradient
                android:angle="0"
                android:startColor="@android:color/transparent"
                android:centerColor="@color/postProcessOrangeSoft"
                android:endColor="@android:color/transparent" />
        </shape>
    </item>
</layer-list>