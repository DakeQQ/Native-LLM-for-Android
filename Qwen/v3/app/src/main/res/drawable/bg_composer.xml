<?xml version="1.0" encoding="utf-8"?>
<!-- Composer "glass sheet": translucent fill rising from the bottom with a rounded top and a thin
     luminous cyan hairline along its top edge. All static gradients — no runtime cost. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="@color/glassFill"
                android:endColor="@color/glassFillStrong" />
            <corners
                android:topLeftRadius="@dimen/ui_corner_radius"
                android:topRightRadius="@dimen/ui_corner_radius" />
            <stroke
                android:width="1dp"
                android:color="@color/glassStroke" />
        </shape>
    </item>
    <!-- Top luminous hairline (inset so it stays within the rounded top). -->
    <item
        android:gravity="top"
        android:height="2dp"
        android:left="28dp"
        android:right="28dp"
        android:top="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="0"
                android:startColor="@android:color/transparent"
                android:centerColor="@color/techCyan"
                android:endColor="@android:color/transparent" />
        </shape>
    </item>
</layer-list>
