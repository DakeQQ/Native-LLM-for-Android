<?xml version="1.0" encoding="utf-8"?>
<!--
    Fused "command deck" — ONE glass card that hosts the banner, primary actions, decode-strategy
    controls and the telemetry/performance readout. Pure static gradients (no blur / bitmap / runtime
    cost): translucent glass body, a glossy top sheen, a luminous hairline border, an energy-spectrum
    rim across the very top (tech-cyan -> energy-amber -> electric-blue) and a soft glowing line along
    the rounded bottom edge. Light/dark palettes swap every @color automatically.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Glass body. -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="@color/glassFillStrong"
                android:endColor="@color/glassFill" />
            <corners
                android:bottomLeftRadius="@dimen/ui_corner_radius"
                android:bottomRightRadius="@dimen/ui_corner_radius" />
            <stroke
                android:width="1dp"
                android:color="@color/glassStroke" />
        </shape>
    </item>
    <!-- Glossy top sheen (kept clear of the energy rim). -->
    <item
        android:gravity="top"
        android:height="46dp"
        android:left="1dp"
        android:right="1dp"
        android:top="3dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="@color/glassHighlight"
                android:endColor="@android:color/transparent" />
        </shape>
    </item>
    <!-- Energy-spectrum rim across the top edge (the deck's signature accent). -->
    <item
        android:gravity="top"
        android:height="3dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="0"
                android:startColor="@color/techCyan"
                android:centerColor="@color/energyYellow"
                android:endColor="@color/electricBlueGlow" />
        </shape>
    </item>
    <!-- Bottom luminous hairline (inset to stay within the rounded corners). -->
    <item
        android:gravity="bottom"
        android:height="2dp"
        android:left="26dp"
        android:right="26dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="0"
                android:startColor="@android:color/transparent"
                android:centerColor="@color/electricBlueGlow"
                android:endColor="@android:color/transparent" />
        </shape>
    </item>
</layer-list>
