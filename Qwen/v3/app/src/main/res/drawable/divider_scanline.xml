<?xml version="1.0" encoding="utf-8"?>
<!--
    Thin HUD "scan line" used to separate the fused deck's zones: a 1dp hairline that fades in from
    both ends toward a luminous centre. One static gradient — no runtime cost.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:type="linear"
        android:angle="0"
        android:startColor="@android:color/transparent"
        android:centerColor="@color/glassStrokeStrong"
        android:endColor="@android:color/transparent" />
</shape>
