<?xml version="1.0" encoding="utf-8"?>
<!--
    Compute / Memory benchmark page (DayNight palette). Runs the standalone libmembw.so read + STREAM
    bandwidth + FMA compute benchmark off the UI thread, then estimates an attainable decode rate
    (sustained read BW × efficiency ÷ per-token weight bytes) for several model sizes.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/computeScreenBg"
    android:fillViewport="true"
    android:fitsSystemWindows="true"
    android:scrollbars="none"
    tools:context=".ComputeMemoryActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="16dp"
        android:paddingBottom="24dp">

        <!-- ===================== Header ===================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/compute_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_compute_icon_button"
                android:contentDescription="@string/compute_mem_back"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_arrow_back" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:fontFamily="sans-serif-medium"
                    android:maxLines="1"
                    android:text="@string/compute_mem_title"
                    android:textColor="@color/textPrimary"
                    android:textSize="19sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/compute_mem_subtitle"
                    android:textColor="@color/energyYellow"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- ===================== Parameters card ===================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_compute_card"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:letterSpacing="0.04"
                android:text="@string/compute_mem_params_title"
                android:textColor="@color/textPrimary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <!-- Array size (millions of float elements) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="84dp"
                    android:layout_height="wrap_content"
                    android:text="@string/compute_mem_array"
                    android:textColor="@color/textMuted"
                    android:textSize="12sp" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/array_slider"
                    style="@style/Widget.App.Slider"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:stepSize="4"
                    android:value="32"
                    android:valueFrom="4"
                    android:valueTo="64" />

                <TextView
                    android:id="@+id/array_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_compute_pill"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:minWidth="58dp"
                    android:paddingStart="9dp"
                    android:paddingTop="3dp"
                    android:paddingEnd="9dp"
                    android:paddingBottom="3dp"
                    android:text="32 M"
                    android:textColor="@color/energyYellow"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Iterations -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="84dp"
                    android:layout_height="wrap_content"
                    android:text="@string/compute_mem_iterations"
                    android:textColor="@color/textMuted"
                    android:textSize="12sp" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/iter_slider"
                    style="@style/Widget.App.Slider"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:stepSize="5"
                    android:value="10"
                    android:valueFrom="5"
                    android:valueTo="20" />

                <TextView
                    android:id="@+id/iter_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_compute_pill"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:minWidth="58dp"
                    android:paddingStart="9dp"
                    android:paddingTop="3dp"
                    android:paddingEnd="9dp"
                    android:paddingBottom="3dp"
                    android:text="10"
                    android:textColor="@color/energyYellow"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Little-core threads (0 = skip) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="84dp"
                    android:layout_height="wrap_content"
                    android:text="@string/compute_mem_little_threads"
                    android:textColor="@color/textMuted"
                    android:textSize="12sp" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/little_thread_slider"
                    style="@style/Widget.App.Slider"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:stepSize="1"
                    android:value="1"
                    android:valueFrom="0"
                    android:valueTo="8" />

                <TextView
                    android:id="@+id/little_thread_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_compute_pill"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:minWidth="58dp"
                    android:paddingStart="9dp"
                    android:paddingTop="3dp"
                    android:paddingEnd="9dp"
                    android:paddingBottom="3dp"
                    android:text="@string/compute_mem_all"
                    android:textColor="@color/energyYellow"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Big-core threads (0 = skip) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="84dp"
                    android:layout_height="wrap_content"
                    android:text="@string/compute_mem_big_threads"
                    android:textColor="@color/textMuted"
                    android:textSize="12sp" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/big_thread_slider"
                    style="@style/Widget.App.Slider"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:stepSize="1"
                    android:value="1"
                    android:valueFrom="0"
                    android:valueTo="8" />

                <TextView
                    android:id="@+id/big_thread_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_compute_pill"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:minWidth="58dp"
                    android:paddingStart="9dp"
                    android:paddingTop="3dp"
                    android:paddingEnd="9dp"
                    android:paddingBottom="3dp"
                    android:text="@string/compute_mem_all"
                    android:textColor="@color/energyYellow"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Run button + progress -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/run_button"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/energyYellow"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="@string/compute_mem_run"
                    android:textColor="@color/textOnYellow"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:cornerRadius="@dimen/ui_corner_radius"
                    app:icon="@drawable/ic_speed"
                    app:iconGravity="textStart"
                    app:iconSize="20dp"
                    app:iconTint="@color/textOnYellow" />

                <ProgressBar
                    android:id="@+id/run_progress"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginStart="14dp"
                    android:indeterminateTint="@color/energyYellow"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>

        <!-- ===================== Results card ===================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_compute_card"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:letterSpacing="0.04"
                android:text="@string/compute_mem_result_title"
                android:textColor="@color/textPrimary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <!-- Idle / running / error message; hidden once the result tables are built. -->
            <TextView
                android:id="@+id/result_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="2dp"
                android:text="@string/compute_mem_result_idle"
                android:textColor="@color/textMuted"
                android:textSize="12sp" />

            <!-- Native result tables (Bandwidth + Compute) are built here at runtime. -->
            <LinearLayout
                android:id="@+id/result_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="vertical"
                android:visibility="gone" />
        </LinearLayout>

        <!-- ===================== Attainable-rate estimate card ===================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_compute_card"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:letterSpacing="0.04"
                android:text="@string/compute_mem_estimate_title"
                android:textColor="@color/textPrimary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <!-- Always-visible disclaimer: this is an efficiency-scaled estimate, not a real inference measurement. -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/compute_mem_estimate_disclaimer"
                android:textColor="@color/techCyan"
                android:textSize="11sp"
                android:textStyle="bold" />

            <!-- Idle message; hidden once the decode estimate table is built. -->
            <TextView
                android:id="@+id/estimate_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="3dp"
                android:text="@string/compute_mem_estimate_idle"
                android:textColor="@color/textMuted"
                android:textSize="12sp" />

            <!-- Decode estimate efficiency (applies instantly to the estimate table). -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="84dp"
                    android:layout_height="wrap_content"
                    android:text="@string/compute_mem_efficiency"
                    android:textColor="@color/textMuted"
                    android:textSize="12sp" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/efficiency_slider"
                    style="@style/Widget.App.Slider"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:stepSize="5"
                    android:value="80"
                    android:valueFrom="10"
                    android:valueTo="100" />

                <TextView
                    android:id="@+id/efficiency_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_compute_pill"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:minWidth="58dp"
                    android:paddingStart="9dp"
                    android:paddingTop="3dp"
                    android:paddingEnd="9dp"
                    android:paddingBottom="3dp"
                    android:text="@string/compute_mem_efficiency_default"
                    android:textColor="@color/energyYellow"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Native decode-estimate table is built here at runtime. -->
            <LinearLayout
                android:id="@+id/estimate_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="vertical"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
