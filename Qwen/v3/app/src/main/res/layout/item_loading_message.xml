<?xml version="1.0" encoding="utf-8"?>
<!--
    Animated "typing" placeholder, styled as a server bubble. Shown only while beam search decodes
    (it streams nothing until it finishes), so the user sees the model is working instead of a frozen
    screen. The three dots are bounced in sequence by ChatAdapter; the row is removed the moment any
    real reply / result arrives.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="start"
    android:paddingStart="14dp"
    android:paddingEnd="56dp"
    android:paddingTop="5dp"
    android:paddingBottom="5dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/server_message_background"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingTop="16dp"
        android:paddingEnd="20dp"
        android:paddingBottom="16dp">

        <View
            android:id="@+id/dot1"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/dot_loading" />

        <View
            android:id="@+id/dot2"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginStart="7dp"
            android:background="@drawable/dot_loading" />

        <View
            android:id="@+id/dot3"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginStart="7dp"
            android:background="@drawable/dot_loading" />
    </LinearLayout>
</LinearLayout>
