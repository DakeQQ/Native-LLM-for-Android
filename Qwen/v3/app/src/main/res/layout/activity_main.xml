<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/use_think"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main_gradient"
    android:fitsSystemWindows="true"
    tools:context=".MainActivity">

    <!-- =================================================================== -->
    <!-- COMMAND DECK: one fused glass card stacking four zones split by HUD  -->
    <!-- scan-lines: (1) identity banner, (2) primary actions, (3) telemetry/ -->
    <!-- performance readout, (4) collapsible decode-strategy controls.       -->
    <!-- All chrome is static drawables (no blur / bitmap / per-frame work).  -->
    <!-- =================================================================== -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_command_deck"
        android:elevation="10dp"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="14dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- ===================== Zone 1 · Identity ===================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Avatar with a soft energy aura behind it (the aura gently pulses at runtime). -->
            <FrameLayout
                android:layout_width="52dp"
                android:layout_height="52dp">

                <View
                    android:id="@+id/avatar_glow"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_avatar_glow" />

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/role_image"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_gravity="center"
                    android:scaleType="centerCrop"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.Circle"
                    app:strokeColor="@color/energyYellow"
                    app:strokeWidth="2dp"
                    tools:srcCompat="@drawable/psyduck" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:minWidth="0dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.01"
                    android:maxLines="1"
                    android:text="@string/app_title"
                    android:textColor="@color/textPrimary"
                    android:textSize="19sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:id="@+id/status_dot"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_gravity="center_vertical"
                        android:layout_marginEnd="7dp"
                        android:background="@drawable/bg_status_dot" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@string/app_subtitle"
                        android:textColor="@color/energyYellow"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

              <!-- Decode-strategy gear: toggles the collapsible controls (Zone 4). Icons kept compact
                  (34dp / 5dp pad, 24dp glyphs) so a 4th button doesn't squeeze the banner text. -->
            <ImageButton
                android:id="@+id/btn_decode_settings"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_copy_button"
                android:contentDescription="@string/decode_title"
                android:padding="5dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_settings" />

              <!-- Slot system-prompt editor. Live turns inject this text; Organize Memory ON strips it
                  during rebuild, OFF keeps it in cross-turn history. -->
            <ImageButton
                android:id="@+id/btn_system_prompt"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginStart="2dp"
                android:background="@drawable/bg_copy_button"
                android:contentDescription="@string/system_prompt_title"
                android:padding="5dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_system_prompt" />

              <!-- Compute / Memory benchmark page (bandwidth + compute + decode estimate). Independent of the LLM runtime. -->
            <ImageButton
                android:id="@+id/btn_compute"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginStart="2dp"
                android:background="@drawable/bg_copy_button"
                android:contentDescription="@string/compute_mem_title"
                android:padding="5dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_speed" />

            <!-- Light/Dark switch. Sun in dark mode (tap -> light), moon in light (tap -> dark);
                 glyph set in MainActivity from the current uiMode. -->
            <ImageButton
                android:id="@+id/theme_toggle"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginStart="2dp"
                android:background="@drawable/bg_copy_button"
                android:contentDescription="@string/theme_toggle"
                android:padding="5dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_light_mode" />
        </LinearLayout>

        <!-- scan-line -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/divider_scanline" />

        <!-- ===================== Zone 2 · Actions ===================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:baselineAligned="false"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ToggleButton
                android:id="@+id/think_mode"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:layout_weight="1"
                android:background="@drawable/bg_think_mode_toggle"
                android:contentDescription="@string/think_mode"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingStart="10dp"
                android:paddingTop="11dp"
                android:paddingEnd="10dp"
                android:paddingBottom="11dp"
                android:text="@string/think_mode_off"
                android:textAllCaps="false"
                android:textColor="@color/think_mode_button_text"
                android:textOff="@string/think_mode_off"
                android:textOn="@string/think_mode_on"
                android:textSize="13sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/clear"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingStart="10dp"
                android:paddingTop="10dp"
                android:paddingEnd="10dp"
                android:paddingBottom="10dp"
                android:text="@string/clear"
                android:textAllCaps="false"
                android:textColor="@color/energyYellow"
                android:textSize="13sp"
                android:textStyle="bold"
                app:cornerRadius="@dimen/ui_corner_radius"
                app:strokeColor="@color/energyYellow" />
        </LinearLayout>

        <!-- scan-line -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/divider_scanline" />

        <!-- ===================== Zone 3 · Telemetry ===================== -->
        <!--
            Fused performance readout: per-turn throughput (Prefill / Decode tokens/s from the native perf
            payload) + a live system monitor (app CPU% + RAM, ~1 Hz /proc read on a background thread while resumed).
        -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:letterSpacing="0.04"
                android:maxLines="1"
                android:text="@string/perf_panel_title"
                android:textColor="@color/textPrimary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/post_processing_status"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_post_processing_status"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="7dp"
                android:paddingEnd="9dp"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/post_processing_icon"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:background="@drawable/bg_post_processing_icon_glow"
                    android:contentDescription="@string/post_processing_status"
                    android:padding="3dp"
                    android:src="@drawable/ic_post_processing_alert" />

                <TextView
                    android:id="@+id/post_processing_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/post_processing_status"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:shadowColor="@color/postProcessOrangeStroke"
                    android:shadowDx="0"
                    android:shadowDy="0"
                    android:shadowRadius="2" />
            </LinearLayout>
        </LinearLayout>

        <!-- Readouts: Prefill | Decode | CPU | RAM -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:baselineAligned="false"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Prefill cell (tap → throughput chart) -->
            <LinearLayout
                android:id="@+id/perf_prefill_cell"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_perf_cell"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="6dp"
                android:paddingBottom="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:drawableEnd="@drawable/ic_chart_line"
                    android:drawablePadding="3dp"
                    android:ellipsize="end"
                    android:letterSpacing="0.06"
                    android:maxLines="1"
                    android:text="@string/perf_prefill"
                    android:textAllCaps="true"
                    android:textColor="@color/perfMetricLabel"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/perf_prefill_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:fontFamily="monospace"
                    android:text="@string/perf_pending"
                    android:textColor="@color/energyYellow"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="26dp"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:background="@color/sliderTrackInactive" />

            <!-- Decode cell (tap → throughput chart) -->
            <LinearLayout
                android:id="@+id/perf_decode_cell"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_perf_cell"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="6dp"
                android:paddingBottom="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:drawableEnd="@drawable/ic_chart_line"
                    android:drawablePadding="3dp"
                    android:ellipsize="end"
                    android:letterSpacing="0.06"
                    android:maxLines="1"
                    android:text="@string/perf_decode"
                    android:textAllCaps="true"
                    android:textColor="@color/perfMetricLabel"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/perf_decode_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:fontFamily="monospace"
                    android:text="@string/perf_pending"
                    android:textColor="@color/energyYellow"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="26dp"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:background="@color/sliderTrackInactive" />

            <!-- CPU cell (live; tap → system chart) -->
            <LinearLayout
                android:id="@+id/perf_cpu_cell"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_perf_cell"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="6dp"
                android:paddingBottom="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:drawableEnd="@drawable/ic_chart_line"
                    android:drawablePadding="3dp"
                    android:ellipsize="end"
                    android:letterSpacing="0.06"
                    android:maxLines="1"
                    android:text="@string/perf_cpu"
                    android:textAllCaps="true"
                    android:textColor="@color/perfMetricLabel"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/perf_cpu_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:fontFamily="monospace"
                    android:text="@string/perf_pending"
                    android:textColor="@color/energyYellow"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="26dp"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:background="@color/sliderTrackInactive" />

            <!-- RAM cell (live; tap → system chart) -->
            <LinearLayout
                android:id="@+id/perf_mem_cell"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_perf_cell"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="6dp"
                android:paddingBottom="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:drawableEnd="@drawable/ic_chart_line"
                    android:drawablePadding="3dp"
                    android:ellipsize="end"
                    android:letterSpacing="0.06"
                    android:maxLines="1"
                    android:text="@string/perf_mem"
                    android:textAllCaps="true"
                    android:textColor="@color/perfMetricLabel"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/perf_mem_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:fontFamily="monospace"
                    android:text="@string/perf_pending"
                    android:textColor="@color/energyYellow"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Retained chat-memory gauge. The bar fills from the left with the USED portion (history + live
             turn), shading green->red as it fills; the track behind is free headroom. Values from the native
             memory stats (see updateMemoryRemainingDisplay). -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:letterSpacing="0.04"
                    android:maxLines="1"
                    android:text="@string/memory_remaining_label"
                    android:textColor="@color/textMuted"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/memory_remaining_value"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:fontFamily="monospace"
                    android:gravity="end|center_vertical"
                    android:maxLines="1"
                    android:text="@string/perf_pending"
                    android:textColor="@color/techCyan"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Stacked gauge: the used fill grows from the left over the free track. Fill colour set in code
                 from remaining-headroom health; starts empty (scaleX 0). Two draggable markers on top:
                 green = post-reset target, red = rebuild trigger. -->
            <FrameLayout
                android:id="@+id/memory_remaining_track"
                android:layout_width="match_parent"
                android:layout_height="18dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_memory_remaining_track">

                <View
                    android:id="@+id/memory_remaining_bar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_memory_remaining_fill"
                    android:scaleX="0"
                    android:transformPivotX="0dp" />

                <View
                    android:id="@+id/memory_remaining_glow"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:alpha="0"
                    android:background="@drawable/bg_memory_remaining_glow"
                    android:scaleX="0"
                    android:transformPivotX="0dp" />

                <!-- Draggable threshold markers (positioned in code by translationX). green = reset target,
                     red = rebuild trigger. The 9dp width is read by positionThresholdMarkers() to centre them. -->
                <View
                    android:id="@+id/memory_threshold_green"
                    android:layout_width="9dp"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_memory_threshold_green" />

                <View
                    android:id="@+id/memory_threshold_red"
                    android:layout_width="9dp"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_memory_threshold_red" />
            </FrameLayout>

            <!-- Live band caption: 重置 (green target) → 触发 (red trigger). Updated while dragging. -->
            <TextView
                android:id="@+id/memory_band_value"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:fontFamily="monospace"
                android:gravity="center"
                android:text="@string/perf_pending"
                android:textColor="@color/textMuted"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- ===================== Zone 4 · Decode strategy ===================== -->
        <!--
            Decode-strategy controls, opened from the top-bar gear (btn_decode_settings), collapsed by default.
            Beam Size / Top-K: 1..10 (< 2 disables beam; Top-K kept >= Beam Size). Penalty: 0.50..1.00
            (1.00 = off). Defaults (1, 1, 1.00) = argmax.
        -->
        <LinearLayout
            android:id="@+id/decode_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="4dp"
            android:visibility="gone">

            <!-- scan-line separating the telemetry above from the decode controls -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/divider_scanline" />

            <!-- Panel heading -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:contentDescription="@string/decode_title"
                    android:src="@drawable/ic_tune" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="@string/decode_title"
                    android:textColor="@color/textPrimary"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Beam Size -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="96dp"
                    android:layout_height="wrap_content"
                    android:text="@string/beam_label"
                    android:textColor="@color/textMuted"
                    android:textSize="12sp" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/beam_slider"
                    style="@style/Widget.App.Slider"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:stepSize="1"
                    android:value="1"
                    android:valueFrom="1"
                    android:valueTo="10" />

                <TextView
                    android:id="@+id/beam_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_value_pill"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:minWidth="38dp"
                    android:paddingStart="9dp"
                    android:paddingTop="3dp"
                    android:paddingEnd="9dp"
                    android:paddingBottom="3dp"
                    android:text="1"
                    android:textColor="@color/energyYellow"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Top-K -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="96dp"
                    android:layout_height="wrap_content"
                    android:text="@string/top_k_label"
                    android:textColor="@color/textMuted"
                    android:textSize="12sp" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/top_k_slider"
                    style="@style/Widget.App.Slider"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:stepSize="1"
                    android:value="1"
                    android:valueFrom="1"
                    android:valueTo="10" />

                <TextView
                    android:id="@+id/top_k_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_value_pill"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:minWidth="38dp"
                    android:paddingStart="9dp"
                    android:paddingTop="3dp"
                    android:paddingEnd="9dp"
                    android:paddingBottom="3dp"
                    android:text="1"
                    android:textColor="@color/energyYellow"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Repetition Penalty -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="96dp"
                    android:layout_height="wrap_content"
                    android:text="@string/penalty_label"
                    android:textColor="@color/textMuted"
                    android:textSize="12sp" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/penalty_slider"
                    style="@style/Widget.App.Slider"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:stepSize="0.05"
                    android:value="1.0"
                    android:valueFrom="0.5"
                    android:valueTo="1.0" />

                <TextView
                    android:id="@+id/penalty_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_value_pill"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:minWidth="38dp"
                    android:paddingStart="9dp"
                    android:paddingTop="3dp"
                    android:paddingEnd="9dp"
                    android:paddingBottom="3dp"
                    android:text="@string/penalty_off"
                    android:textColor="@color/energyYellow"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Retained cross-turn memory (tokens) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="96dp"
                    android:layout_height="wrap_content"
                    android:text="@string/memory_label"
                    android:textColor="@color/textMuted"
                    android:textSize="12sp" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/memory_slider"
                    style="@style/Widget.App.Slider"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:stepSize="32"
                    android:value="2048"
                    android:valueFrom="256"
                    android:valueTo="8160" />

                <TextView
                    android:id="@+id/memory_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_value_pill"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:minWidth="48dp"
                    android:paddingStart="9dp"
                    android:paddingTop="3dp"
                    android:paddingEnd="9dp"
                    android:paddingBottom="3dp"
                    android:text="2048"
                    android:textColor="@color/energyYellow"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Look-back window (tokens): most-recent memory tokens the new prompt attends to during
                 prefill (decode still sees the full window). Labelled 回溯 / Look-back in the UI. -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="96dp"
                    android:layout_height="wrap_content"
                    android:text="@string/prefill_label"
                    android:textColor="@color/textMuted"
                    android:textSize="12sp" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/prefill_slider"
                    style="@style/Widget.App.Slider"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:stepSize="32"
                    android:value="256"
                    android:valueFrom="0"
                    android:valueTo="8160" />

                <TextView
                    android:id="@+id/prefill_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_value_pill"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:minWidth="48dp"
                    android:paddingStart="9dp"
                    android:paddingTop="3dp"
                    android:paddingEnd="9dp"
                    android:paddingBottom="3dp"
                    android:text="256"
                    android:textColor="@color/energyYellow"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Per-turn decode cap (tokens) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="96dp"
                    android:layout_height="wrap_content"
                    android:text="@string/decode_limit_label"
                    android:textColor="@color/textMuted"
                    android:textSize="12sp" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/decode_limit_slider"
                    style="@style/Widget.App.Slider"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:stepSize="1"
                    android:value="4095"
                    android:valueFrom="2"
                    android:valueTo="8192" />

                <TextView
                    android:id="@+id/decode_limit_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_value_pill"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:minWidth="48dp"
                    android:paddingStart="9dp"
                    android:paddingTop="3dp"
                    android:paddingEnd="9dp"
                    android:paddingBottom="3dp"
                    android:text="4095"
                    android:textColor="@color/energyYellow"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- ===================== 整理记忆 / Organize Memory (default off) ===================== -->
            <!--
                Trigger toggle. ON = native removes the current turn's system prompt during clean recompute.
                OFF (default) = every live turn still injects the prompt and keeps it in cross-turn memory
                unless a later cap trim drops it. Pushed to native via Configure_Organize_Memory.
            -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/organize_memory_label"
                        android:textColor="@color/textPrimary"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="1dp"
                        android:text="@string/organize_memory_hint"
                        android:textColor="@color/textMuted"
                        android:textSize="10sp" />
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/organize_memory_switch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:checked="false"
                    android:contentDescription="@string/organize_memory_label"
                    app:thumbTint="@color/switch_thumb_tint"
                    app:trackTint="@color/switch_track_tint" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- ===================== Chat history ===================== -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/result_text"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@+id/input_bar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/header" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/jump_to_bottom"
        android:layout_width="wrap_content"
        android:layout_height="38dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="12dp"
        android:backgroundTint="@color/energyYellow"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:text="@string/jump_to_bottom"
        android:textColor="@color/textOnYellow"
        android:textSize="12sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:cornerRadius="@dimen/ui_corner_radius"
        app:elevation="6dp"
        app:icon="@drawable/ic_expand_more"
        app:iconGravity="textStart"
        app:iconSize="18dp"
        app:iconTint="@color/textOnYellow"
        app:layout_constraintBottom_toTopOf="@+id/input_bar"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ===================== Composer ===================== -->
    <LinearLayout
        android:id="@+id/input_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_composer"
        android:elevation="0dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/input_text"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="@drawable/bg_input_field"
            android:gravity="center_vertical"
            android:hint="@string/type_your_message"
            android:inputType="textMultiLine|textCapSentences"
            android:maxLines="4"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:textColor="@color/textPrimary"
            android:textColorHint="@color/textMuted"
            android:textSize="15sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/send"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginStart="10dp"
            android:backgroundTint="@color/energyYellow"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="@string/send"
            android:textColor="@color/textOnYellow"
            android:textSize="14sp"
            android:textStyle="bold"
            app:cornerRadius="@dimen/ui_corner_radius"
            app:elevation="0dp"
            app:icon="@drawable/ic_send"
            app:iconGravity="textStart"
            app:iconSize="18dp"
            app:iconTint="@color/textOnYellow" />

        <!-- Shown only while a reply streams; halts decode like a stop token + tags it manually stopped. -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/stop"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginStart="10dp"
            android:backgroundTint="@color/stopRed"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="@string/stop"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:cornerRadius="@dimen/ui_corner_radius"
            app:elevation="0dp"
            app:icon="@drawable/ic_stop"
            app:iconGravity="textStart"
            app:iconSize="18dp"
            app:iconTint="@color/white" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
