<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/thinkToggleCheckedBase" />
                    <corners android:radius="@dimen/ui_corner_radius" />
                </shape>
            </item>
            <item
                android:bottom="3dp"
                android:left="3dp"
                android:right="3dp"
                android:top="3dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:type="linear"
                        android:angle="270"
                        android:startColor="@color/energyYellow"
                        android:endColor="@color/energyYellowDeep" />
                    <corners android:radius="@dimen/ui_corner_radius_small" />
                    <stroke
                        android:width="1dp"
                        android:color="@color/energyYellow" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/thinkTogglePressed" />
            <corners android:radius="@dimen/ui_corner_radius" />
            <stroke
                android:width="1dp"
                android:color="@color/energyYellow" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/glassFill" />
            <corners android:radius="@dimen/ui_corner_radius" />
            <stroke
                android:width="1dp"
                android:color="@color/energyYellow" />
        </shape>
    </item>
</selector>