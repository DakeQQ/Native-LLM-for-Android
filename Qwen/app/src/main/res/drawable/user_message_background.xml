<?xml version="1.0" encoding="utf-8"?>
<!-- User bubble: electric-blue glass with a glossy top sheen and a compact rectangular edge. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="@color/userFillTop"
                android:endColor="@color/userFillBottom" />
            <corners android:radius="@dimen/ui_corner_radius" />
            <stroke
                android:width="1dp"
                android:color="@color/userStroke" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="@color/glassHighlight"
                android:endColor="@android:color/transparent" />
            <corners android:radius="@dimen/ui_corner_radius" />
        </shape>
    </item>
</layer-list>