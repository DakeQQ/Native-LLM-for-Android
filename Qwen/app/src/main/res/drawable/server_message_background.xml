<?xml version="1.0" encoding="utf-8"?>
<!-- Assistant bubble: frosted glass with a luminous energy-yellow edge and compact rectangular corners. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="@color/assistantFillTop"
                android:endColor="@color/assistantFillBottom" />
            <corners android:radius="@dimen/ui_corner_radius" />
            <stroke
                android:width="1.5dp"
                android:color="@color/assistantStroke" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="@color/glassHighlight"
                android:endColor="@android:color/transparent" />
            <corners android:radius="@dimen/ui_corner_radius" />
        </shape>
    </item>
</layer-list>