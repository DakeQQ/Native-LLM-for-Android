<?xml version="1.0" encoding="utf-8"?>
<!-- Draggable "reset target" marker on the memory bar (where a rebuild lands). Solid green core + a
     theme-adaptive outline (textPrimary flips dark/light) so it stays visible on any fill colour. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/statusOnline" />
    <corners android:radius="3dp" />
    <stroke
        android:width="1.5dp"
        android:color="@color/textPrimary" />
</shape>
