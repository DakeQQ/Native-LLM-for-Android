<?xml version="1.0" encoding="utf-8"?>
<!-- Tappable performance-panel cell: visible idle stroke/fill makes the chart affordance obvious, while
     the bounded ripple avoids the theme's oversized borderless blue ripple. -->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/glassStrokeStrong">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/ui_corner_radius" />
            <solid android:color="@color/glassFillStrong" />
            <stroke
                android:width="1dp"
                android:color="@color/glassStrokeStrong" />
        </shape>
    </item>
    <item android:id="@android:id/mask">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/ui_corner_radius" />
            <solid android:color="@android:color/white" />
        </shape>
    </item>
</ripple>
