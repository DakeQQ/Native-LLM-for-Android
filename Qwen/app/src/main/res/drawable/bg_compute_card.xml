<?xml version="1.0" encoding="utf-8"?>
<!--
    Compute / Memory page card surface. Uses DayNight compute colours so the page follows
    the main app theme while keeping the same card geometry in both modes.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/ui_corner_radius" />
            <gradient
                android:angle="270"
                android:startColor="@color/computeCardStart"
                android:endColor="@color/computeCardEnd" />
            <stroke
                android:width="1dp"
                android:color="@color/computeCardStroke" />
        </shape>
    </item>
    <!-- top sheen -->
    <item
        android:bottom="1dp"
        android:left="1dp"
        android:right="1dp"
        android:top="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/ui_corner_radius_inner" />
            <gradient
                android:angle="270"
                android:startColor="#1FFFFFFF"
                android:centerColor="#00FFFFFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>
</layer-list>
