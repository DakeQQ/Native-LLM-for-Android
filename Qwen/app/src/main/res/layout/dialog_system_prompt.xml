<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_system_prompt_panel"
    android:orientation="vertical"
    android:paddingStart="18dp"
    android:paddingTop="18dp"
    android:paddingEnd="18dp"
    android:paddingBottom="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_copy_button"
            android:contentDescription="@string/system_prompt_title"
            android:padding="9dp"
            android:src="@drawable/ic_system_prompt" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/system_prompt_title"
                android:textColor="@color/textPrimary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="@string/system_prompt_subtitle"
                android:textColor="@color/textMuted"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_value_pill"
            android:fontFamily="monospace"
            android:gravity="center"
            android:minWidth="66dp"
            android:paddingStart="9dp"
            android:paddingTop="4dp"
            android:paddingEnd="9dp"
            android:paddingBottom="4dp"
            android:text="@string/system_prompt_scope"
            android:textColor="@color/energyYellow"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/divider_scanline" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="@string/system_prompt_editor_label"
        android:textColor="@color/textPrimary"
        android:textSize="13sp"
        android:textStyle="bold" />

    <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/systemPromptInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_input_field"
        android:gravity="top|start"
        android:hint="@string/system_prompt_hint"
        android:imeOptions="flagNoExtractUi"
        android:inputType="textMultiLine|textCapSentences|textNoSuggestions"
        android:lineSpacingExtra="2dp"
        android:maxLines="14"
        android:minHeight="220dp"
        android:minLines="8"
        android:overScrollMode="ifContentScrolls"
        android:paddingStart="16dp"
        android:paddingTop="14dp"
        android:paddingEnd="16dp"
        android:paddingBottom="14dp"
        android:scrollbars="vertical"
        android:textColor="@color/textPrimary"
        android:textColorHint="@color/textMuted"
        android:textSize="15sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/system_prompt_meta"
            android:textColor="@color/textMuted"
            android:textSize="11.5sp" />

        <TextView
            android:id="@+id/systemPromptCounter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_value_pill"
            android:fontFamily="monospace"
            android:gravity="center"
            android:minWidth="64dp"
            android:paddingStart="8dp"
            android:paddingTop="3dp"
            android:paddingEnd="8dp"
            android:paddingBottom="3dp"
            android:textColor="@color/energyYellow"
            android:textSize="11sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/systemPromptClear"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:backgroundTint="@color/glassFillStrong"
            android:ellipsize="end"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:maxLines="1"
            android:minWidth="0dp"
            android:text="@string/system_prompt_clear"
            android:textColor="@color/textMuted"
            android:textSize="13sp"
            app:cornerRadius="@dimen/ui_corner_radius"
            app:elevation="0dp"
            app:strokeColor="@color/glassStrokeStrong"
            app:strokeWidth="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/systemPromptReset"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:backgroundTint="@color/glassFillStrong"
            android:ellipsize="end"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:maxLines="1"
            android:minWidth="0dp"
            android:text="@string/system_prompt_reset"
            android:textColor="@color/textMuted"
            android:textSize="13sp"
            app:cornerRadius="@dimen/ui_corner_radius"
            app:elevation="0dp"
            app:strokeColor="@color/glassStrokeStrong"
            app:strokeWidth="1dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/systemPromptCancel"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:backgroundTint="@color/glassFill"
            android:ellipsize="end"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:maxLines="1"
            android:minWidth="0dp"
            android:text="@string/system_prompt_cancel"
            android:textColor="@color/textPrimary"
            android:textSize="14sp"
            android:textStyle="bold"
            app:cornerRadius="@dimen/ui_corner_radius"
            app:elevation="0dp"
            app:strokeColor="@color/glassStrokeStrong"
            app:strokeWidth="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/systemPromptSave"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:backgroundTint="@color/energyYellow"
            android:ellipsize="end"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:maxLines="1"
            android:minWidth="0dp"
            android:text="@string/system_prompt_save"
            android:textColor="@color/textOnYellow"
            android:textSize="14sp"
            android:textStyle="bold"
            app:cornerRadius="@dimen/ui_corner_radius"
            app:elevation="0dp" />
    </LinearLayout>
</LinearLayout>