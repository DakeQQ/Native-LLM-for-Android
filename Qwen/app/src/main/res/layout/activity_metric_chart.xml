<?xml version="1.0" encoding="utf-8"?>
<!--
    Full-screen telemetry chart (CPU/RAM over time, or prefill/decode token-total vs speed).
    MetricChartView draws + handles zoom/pan; this layout supplies the header, legend toggles, zoom
    controls and data-reset action. DayNight palette (chart* colours).
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgDark"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingTop="12dp"
    android:paddingEnd="16dp"
    android:paddingBottom="16dp"
    tools:context=".MetricChartActivity">

    <!-- ===================== Header ===================== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/metric_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_compute_icon_button"
            android:contentDescription="@string/compute_mem_back"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_arrow_back" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/metric_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:text="@string/chart_title_system"
                android:textColor="@color/textPrimary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/metric_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="monospace"
                android:letterSpacing="0.02"
                android:maxLines="1"
                android:text="@string/chart_subtitle_system"
                android:textColor="@color/textMuted"
                android:textSize="11sp" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/metric_clear"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_compute_icon_button"
            android:contentDescription="@string/chart_clear"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_refresh" />
    </LinearLayout>

    <!-- ===================== Legend toggles ===================== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/legend_a"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_chart_chip"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingTop="7dp"
            android:paddingEnd="14dp"
            android:paddingBottom="7dp">

            <View
                android:id="@+id/legend_a_dot"
                android:layout_width="11dp"
                android:layout_height="11dp"
                android:background="@drawable/bg_chart_dot" />

            <TextView
                android:id="@+id/legend_a_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:fontFamily="monospace"
                android:text="@string/chart_series_cpu"
                android:textColor="@color/textPrimary"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/legend_b"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:background="@drawable/bg_chart_chip"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingTop="7dp"
            android:paddingEnd="14dp"
            android:paddingBottom="7dp">

            <View
                android:id="@+id/legend_b_dot"
                android:layout_width="11dp"
                android:layout_height="11dp"
                android:background="@drawable/bg_chart_dot" />

            <TextView
                android:id="@+id/legend_b_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:fontFamily="monospace"
                android:text="@string/chart_series_mem"
                android:textColor="@color/textPrimary"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- ===================== Chart ===================== -->
    <com.example.myapplication.MetricChartView
        android:id="@+id/metric_chart"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1" />

    <!-- ===================== Zoom controls ===================== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/metric_zoom_out"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_compute_icon_button"
            android:contentDescription="@string/chart_zoom_out"
            android:padding="9dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_zoom_out" />

        <ImageButton
            android:id="@+id/metric_fit"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="18dp"
            android:background="@drawable/bg_compute_icon_button"
            android:contentDescription="@string/chart_fit"
            android:padding="9dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_fit_screen" />

        <ImageButton
            android:id="@+id/metric_zoom_in"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="18dp"
            android:background="@drawable/bg_compute_icon_button"
            android:contentDescription="@string/chart_zoom_in"
            android:padding="9dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_zoom_in" />
    </LinearLayout>

    <TextView
        android:id="@+id/metric_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:text="@string/chart_hint"
        android:textColor="@color/textMuted"
        android:textSize="11sp" />
</LinearLayout>
