<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="start"
    android:paddingStart="14dp"
    android:paddingEnd="56dp"
    android:paddingTop="5dp"
    android:paddingBottom="5dp">

    <TextView
        android:id="@+id/messageTimeTop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="3dp"
        android:alpha="0.72"
        android:includeFontPadding="false"
        android:textColor="@color/textMuted"
        android:textSize="11sp" />

    <!-- Collapsible "internal contemplation" panel. Hidden unless the reply carries a chain-of-thought;
         the header (chevron + label) toggles the dimmed reasoning body. Bound in ChatAdapter. -->
    <LinearLayout
        android:id="@+id/thinkContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="6dp"
        android:background="@drawable/bg_think_block"
        android:clickable="true"
        android:focusable="true"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="7dp"
        android:paddingBottom="7dp"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/thinkHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackgroundBorderless">

            <TextView
                android:id="@+id/thinkChevron"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:text="@string/think_chevron_expanded"
                android:textColor="@color/thinkText"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/thinkTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/think_section_active"
                android:textColor="@color/thinkText"
                android:textSize="12.5sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/thinkText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/thinkText"
            android:textSize="14sp"
            android:textStyle="italic"
            android:lineSpacingExtra="2dp"
            android:textIsSelectable="false"
            android:visibility="gone" />
    </LinearLayout>

    <TextView
        android:id="@+id/messageText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/server_message_background"
        android:textColor="@color/assistantText"
        android:textSize="16sp"
        android:lineSpacingExtra="2dp"
        android:paddingStart="16dp"
        android:paddingTop="11dp"
        android:paddingEnd="16dp"
        android:paddingBottom="11dp"
        android:textIsSelectable="true" />

    <TextView
        android:id="@+id/messageTimeBottom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:alpha="0.72"
        android:includeFontPadding="false"
        android:textColor="@color/textMuted"
        android:textSize="11sp" />

    <!-- One-tap copy: lifts this reply's text to the system clipboard. Sits just below the bubble,
         left-aligned, as an unobtrusive secondary affordance (muted glyph + borderless ripple). -->
    <ImageButton
        android:id="@+id/copyButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="6dp"
        android:layout_marginTop="2dp"
        android:padding="6dp"
        android:background="@drawable/bg_copy_button"
        android:src="@drawable/ic_copy"
        android:scaleType="centerInside"
        android:contentDescription="@string/copy_message" />
</LinearLayout>
