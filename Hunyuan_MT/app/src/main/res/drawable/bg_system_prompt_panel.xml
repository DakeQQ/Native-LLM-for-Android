<?xml version="1.0" encoding="utf-8"?>
<!-- Full system-prompt editor sheet: the same glass/energy vocabulary as the chat command deck, but
     rounded on all corners because it floats as a dialog. Static drawable only; no runtime blur. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="@color/systemPromptPanelFillStrong"
                android:endColor="@color/systemPromptPanelFill" />
            <corners android:radius="@dimen/ui_corner_radius" />
            <stroke
                android:width="1dp"
                android:color="@color/glassStroke" />
        </shape>
    </item>

    <item
        android:gravity="top"
        android:height="46dp"
        android:left="1dp"
        android:right="1dp"
        android:top="3dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="@color/glassHighlight"
                android:endColor="@android:color/transparent" />
            <corners android:radius="@dimen/ui_corner_radius" />
        </shape>
    </item>

    <item
        android:gravity="top"
        android:height="3dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="0"
                android:startColor="@color/techCyan"
                android:centerColor="@color/energyYellow"
                android:endColor="@color/electricBlueGlow" />
            <corners
                android:topLeftRadius="@dimen/ui_corner_radius"
                android:topRightRadius="@dimen/ui_corner_radius" />
        </shape>
    </item>

    <item
        android:gravity="bottom"
        android:height="2dp"
        android:left="24dp"
        android:right="24dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="0"
                android:startColor="@android:color/transparent"
                android:centerColor="@color/electricBlueGlow"
                android:endColor="@android:color/transparent" />
        </shape>
    </item>
</layer-list>