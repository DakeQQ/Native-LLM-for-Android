<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/ui_corner_radius_small" />
            <gradient
                android:type="radial"
                android:startColor="@color/postProcessOrangeSoft"
                android:centerColor="@color/postProcessOrangeSoft"
                android:endColor="@android:color/transparent"
                android:gradientRadius="10dp" />
        </shape>
    </item>
    <item
        android:left="5dp"
        android:top="5dp"
        android:right="5dp"
        android:bottom="5dp">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/ui_corner_radius_tiny" />
            <solid android:color="@color/postProcessOrangeSoft" />
        </shape>
    </item>
</layer-list>