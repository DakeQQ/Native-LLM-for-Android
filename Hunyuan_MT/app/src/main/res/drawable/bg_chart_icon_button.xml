<?xml version="1.0" encoding="utf-8"?>
<!-- Compact rectangular ripple for full-screen chart controls. -->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/chartIconButtonRipple">
    <item android:id="@android:id/mask">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/ui_corner_radius" />
            <solid android:color="#FFFFFFFF" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/ui_corner_radius" />
            <solid android:color="@color/chartIconButtonFill" />
        </shape>
    </item>
</ripple>