<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- ===== Energy theme · high-contrast Blue / Yellow ===== -->
    <style name="Theme.NativeLLM" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Electric blue primary -->
        <item name="colorPrimary">@color/electricBlue</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/electricBlueDeep</item>
        <!-- Energy yellow accent -->
        <item name="colorSecondary">@color/energyYellow</item>
        <item name="colorOnSecondary">@color/textOnYellow</item>
        <item name="colorTertiary">@color/energyYellow</item>
        <!-- Surfaces -->
        <item name="android:colorBackground">@color/bgDark</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/textPrimary</item>
        <item name="colorControlHighlight">@color/electricBlueGlow</item>
        <!-- System bars -->
        <item name="android:statusBarColor">@color/bgDark</item>
        <item name="android:navigationBarColor">@color/bgDark</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Backwards-compatible alias for the previous theme name. -->
    <style name="Theme.MyApplication" parent="Theme.NativeLLM" />

    <!-- Circular crop for the avatar (ShapeableImageView). -->
    <style name="ShapeAppearance.Circle" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>
</resources>